Cell[BoxData[
 RowBox[{
  RowBox[{"TwistedSolidSurface", "[", 
   RowBox[{
    RowBox[{"directrix_", ":", 
     RowBox[{"{", 
      RowBox[{"_", ",", "_", ",", "_", ",", "_"}], "}"}]}], ",", 
    RowBox[{"fiber_", ":", 
     RowBox[{"{", 
      RowBox[{"_", ",", "_"}], "}"}]}], ",", "twistAngle1_", ",", 
    "twistAngle2_", ",", 
    RowBox[{"{", 
     RowBox[{"u_", ",", "v_", ",", "w_"}], "}"}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "a1", ",", "a2", ",", "f", ",", "T1", ",", "T2", ",", "aux", ",", "mr", ",",
       "N1", ",", "N2"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"a1", "=", 
      RowBox[{"twistAngle1", "*", 
       RowBox[{"u", "/", "2"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"a2", "=", 
      RowBox[{"twistAngle2", "*", "v"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"f", "=", 
      RowBox[{"fiber", "[", "w", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"T1", ",", "T2"}], "}"}], "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"directrix", "[", 
          RowBox[{"u", ",", "v"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"u", ",", "v"}], "}"}], "}"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"aux", "=", 
      RowBox[{"Plus", "@@", 
       RowBox[{"Transpose", "[", 
        RowBox[{"Flatten", "/@", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"directrix", "[", 
            RowBox[{"u", ",", "v"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"u", ",", "v"}], "}"}], ",", "2"}], "}"}]}], "]"}]}], 
        "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"mr", "=", 
      RowBox[{"MatrixRank", "[", 
       RowBox[{"{", 
        RowBox[{"T1", ",", "T2", ",", "aux"}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"mr", "<", "3"}], ",", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{
